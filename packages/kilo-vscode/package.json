{
  "name": "blitz-code",
  "displayName": "Blitz: AI Coding Agent, Copilot, and Autocomplete",
  "description": "Open Source AI coding agent that generates code from natural language, automates tasks, and runs terminal commands. Features inline autocomplete, browser automation, automated refactoring, and custom modes for planning, coding, and debugging. Supports 500+ AI models including Claude (Anthropic), Gemini, Grok, GPT, Codex and GLM.",
  "version": "1.0.0",
  "icon": "assets/icons/logo-outline-black.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "publisher": "blitzcode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kilo-Org/kilocode.git",
    "directory": "packages/kilo-vscode"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "license": "MIT",
  "author": {
    "name": "Blitz"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "blitz",
    "Blitz",
    "blitzcode",
    "ai",
    "agent",
    "agentic",
    "coding",
    "coding agent",
    "coding assistant",
    "autocomplete",
    "code completion",
    "pair programming",
    "chat",
    "terminal",
    "chatgpt",
    "claude",
    "sonnet",
    "anthropic",
    "openai",
    "zoo code",
    "opencode",
    "open code"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "blitz-worktree-setup",
        "properties": {
          "script": {
            "type": "string",
            "description": "The setup script command to execute"
          }
        }
      }
    ],
    "icons": {
      "blitz-logo": {
        "description": "Blitz logo",
        "default": {
          "fontPath": "assets/icons/blitz-icon-font.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "blitz-code-ActivityBar",
          "title": "Blitz",
          "icon": "assets/icons/blitz-light.png",
          "darkIcon": "assets/icons/blitz-dark.png"
        }
      ]
    },
    "views": {
      "blitz-code-ActivityBar": [
        {
          "type": "webview",
          "id": "blitz-code.SidebarProvider",
"name": "Blitz"
        }
      ]
    },
