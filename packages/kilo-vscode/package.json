    "submenus": [
      {
        "id": "blitz-code.new.editorContextMenu",
        "label": "Blitz"
      },
      {
        "id": "blitz-code.new.terminalContextMenu",
        "label": "Blitz"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "blitz-code.new.sidebarTitle.plusButtonClicked",
          "when": "false"
        },
        {
          "command": "blitz-code.new.sidebarTitle.historyButtonClicked",
          "when": "false"
        },
        {
          "command": "blitz-code.new.sidebarTitle.agentManagerOpen",
          "when": "false"
        },
        {
          "command": "blitz-code.new.sidebarTitle.marketplaceButtonClicked",
          "when": "false"
        },
        {
          "command": "blitz-code.new.sidebarTitle.profileButtonClicked",
          "when": "false"
        },
        {
          "command": "blitz-code.new.sidebarTitle.settingsButtonClicked",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "blitz-code.new.sidebarTitle.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == blitz-code.SidebarProvider"
        },
        {
          "command": "blitz-code.new.sidebarTitle.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == blitz-code.SidebarProvider"
        },
        {
          "command": "blitz-code.new.sidebarTitle.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == blitz-code.SidebarProvider"
        },
        {
          "command": "blitz-code.new.sidebarTitle.marketplaceButtonClicked",
          "group": "navigation@3",
          "when": "view == blitz-code.SidebarProvider"
        },
        {
          "command": "blitz-code.new.sidebarTitle.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == blitz-code.SidebarProvider"
        },
        {
          "command": "blitz-code.new.sidebarTitle.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == blitz-code.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "blitz-code.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "blitz-code.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "blitz-code.new.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "blitz-code.new.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == blitz-code.new.TabPanel"
        },
        {
          "command": "blitz-code.new.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == blitz-code.new.TabPanel"
        },
        {
          "command": "blitz-code.new.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == blitz-code.new.TabPanel"
        },
        {
          "command": "blitz-code.new.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == blitz-code.new.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "blitz-code.new.editorContextMenu",
          "group": "1_blitzcode"
        }
      ],
      "blitz-code.new.editorContextMenu": [
        {
          "command": "blitz-code.new.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "blitz-code.new.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "blitz-code.new.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "blitz-code.new.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "blitz-code.new.terminalContextMenu",
          "group": "2_blitzcode"
        }
      ],
      "blitz-code.new.terminalContextMenu": [
        {
          "command": "blitz-code.new.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "blitz-code.new.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "blitz-code.new.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "blitz-code.new.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "blitz-code.new.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "blitz-code.new.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "blitz-code.new.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "blitz-code.new.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "blitz-code.new.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel' && !terminalFocus"
      },
      {
        "command": "blitz-code.new.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "blitz-code.new.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.openPR",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
