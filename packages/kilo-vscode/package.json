      },
      {
        "command": "blitz-code.new.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
      },
      {
        "command": "blitz-code.new.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'blitz-code.new.AgentManagerPanel'"
